{
  "name": "percolator-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Routing layer for Percolator: iOS, terminal, and Telegram clients connect through a single backend that registers/mints/explores Solana agents via Metaplex and Helius RPC.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p .",
    "server": "node --enable-source-maps dist/server/index.js",
    "cli": "node --enable-source-maps dist/cli/index.js",
    "telegram": "node --enable-source-maps dist/telegram/bot.js",
    "dev:server": "tsx src/server/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:telegram": "tsx src/telegram/bot.ts",
    "typecheck": "tsc -p . --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "bin": {
    "percolator-agent": "./dist/cli/index.js"
  },
  "dependencies": {
    "@metaplex-foundation/mpl-agent-registry": "^0.1.0",
    "@metaplex-foundation/mpl-core": "^1.1.1",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@metaplex-foundation/umi-uploader-irys": "^0.9.2",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "grammy": "^1.30.0",
    "helius-sdk": "^1.4.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
