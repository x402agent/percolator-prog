# --- Solana / Helius ---
# Paid Helius URL (mainnet or devnet). The API key is part of the URL.
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_CLUSTER=devnet

# Operator hot wallet secret key. Two accepted formats:
#   1) The full JSON byte array straight out of solana-keygen, e.g. [12,34,...,255]
#      Generate: solana-keygen new --no-bip39-passphrase -o keypair.json
#      Then:     OPERATOR_SECRET_KEY=$(cat keypair.json)   # keep the brackets
#   2) A base58-encoded secret (single token, no commas), e.g. produced by
#      `solana-keygen base58` or any wallet export. Paste it as-is.
# Never commit the real value.
OPERATOR_SECRET_KEY=

# --- HTTP server ---
PORT=8787
# Shared API key checked on every HTTP request (iOS + CLI). Min 24 chars.
API_KEY=

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs that are allowed to use the bot.
TELEGRAM_ALLOWED_CHATS=

# --- Percolator program (optional, for explorer cross-links) ---
PERCOLATOR_PROGRAM_ID=
